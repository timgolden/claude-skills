/*Color Scheme Mapping:0:  #F099A7  // Blush Pink1:  #F2A948  // Golden Apricot2:  #C49B40  // Mustard Gold3:  #F6F48D  // Light Lemon4:  #CBF94F  // Lime Zest5:  #78FB58  // Neon Lime6:  #7AFBAF  // Minty Aqua7:  #8DFCE8  // Seafoam8:  #97C3FA  // Baby Blue9:  #5E7FDD  // Royal Blue10: #96A6F9  // Lavender Blue11: #CA72DE  // Amethyst12: #D45D9E  // Fuchsia Rose13: #FFFFFF  // White14: #EB4A41  // Bright Red15: #E5742E  // Tangerine16: #91644F  // Rustic Brown17: #FCF15E  // Sunny Yellow18: #A5FC7C  // Fresh Green19: #67C039  // Kelly Green20: #56BCAF  // Turquoise21: #6DE6FC  // Aqua Blue22: #4BA2E8  // Cerulean23: #367BBB  // Cobalt Blue24: #846DDD  // Lavender Purple25: #AD7AC1  // Mauve26: #EB4CCE  // Hot Magenta27: #D0D0D0  // Light Gray28: #D56F60  // Rusty Clay29: #F2A77C  // Peach30: #CDAE79  // Antique Gold31: #F0FEB7  // Pastel Yellow32: #D5E3A0  // Pistachio33: #BECF7F  // Olive34: #A3C392  // Sage35: #DCFCE3  // Mint Cream36: #D4F0F7  // Icy Blue37: #BAC1E0  // Periwinkle Blue38: #CABCE1  // Soft Lavender39: #AA99E0  // Wisteria40: #E3DCE1  // Misty Mauve41: #A9A9A9  // Gray42: #DA968E  // Dusty Rose43: #AF845D  // Taupe44: #95846D  // Earthy Taupe45: #BEBA74  // Olive Drab46: #ABBD3B  // Lime Green47: #88AF5A  // Avocado Green48: #95C0BA  // Dusty Teal49: #A0B2C2  // Slate Blue50: #8BA4C4  // Steel Blue51: #8692C8  // Pastel Periwinkle52: #A296B3  // Dusty Lavender53: #BAA0BC  // Orchid Mist54: #B27594  // Rose Quartz55: #7B7B7B  // Medium Gray56: #A13D38  // Brick Red57: #9E5639  // Burnt Sienna58: #6D5043  // Chocolate59: #D7C440  // Mustard Yellow60: #889537  // Olive Grove61: #669D42  // Forest Green62: #469A8E  // Deep Teal63: #356281  // Navy64: #1F2E90  // Midnight Blue65: #37519D  // Cobalt66: #5E4CA7  // Indigo67: #9850A8  // Vivid Violet68: #BC3D6D  // Raspberry69: #3C3C3C  // Charcoal70: #000000  // Black71: #EA3323  // Fire Red72: #75FB4C  // Neon Green73: #FFFF54  // Lemon Yellow74: #0000F5  // Vivid Blue75: #EA33F7  // Vivid Magenta76: #75FBFD  // Aqua77: #75140C  // Deep Maroon78: #808026  // Olive Brown79: #377E22  // Deep Forest Green80: #377E7F  // Sea Teal81: #00007B  // Deep Navy82: #75147C  // Deep Plum*/{  "$schema": "http://json-schema.org/draft-07/schema#",  "title": "ROTO-CONTROL Export File",  "description": "This schema defines the export file format for ROTO-CONTROL. It includes top-level metadata, an array of knob definitions, and an array of button definitions.",  "type": "object",  "properties": {    "version": {      "type": "integer",      "description": "The version number of the export file format."    },    "type": {      "type": "string",      "description": "The type of export (e.g., 'MIDI')."    },    "name": {      "type": "string",      "description": "The name of the export preset or configuration."    },    "index": {      "type": "integer",      "description": "An index used to identify this export configuration."    },    "knobs": {      "type": "array",      "description": "An array of knob control definitions.",      "items": {        "type": "object",        "description": "Definition of a single knob control.",        "properties": {          "controlIndex": {            "type": "integer",	    "minimum": 0,            "maximum": 31,            "description": "The index of the knob control (starting at 0)."          },          "controlMode": {            "type": "integer",            "description": "The mode of the control (e.g., 0 for a standard mode)."          },          "controlChannel": {            "type": "integer",	    "minimum": 1,            "maximum": 16,            "description": "The MIDI channel for this knob control."          },          "controlParam": {            "type": "integer",            "description": "The MIDI control parameter number assigned to this knob."          },          "nrpnAddress": {            "type": "integer",            "description": "The NRPN (Non-Registered Parameter Number) address, if applicable."          },          "minValue": {            "type": "integer",	    "minimum": 0,            "maximum": 127,            "description": "The minimum value that the knob can output."          },          "maxValue": {            "type": "integer",	    "minimum": 0,            "maximum": 127,            "description": "The maximum value that the knob can output."          },          "controlName": {            "type": "string",            "description": "A human‑readable name for the knob control."          },          "colorScheme": {            "type": "integer",	    "minimum": 0,            "maximum": 82,            "description": "An identifier for the color scheme used for this knob."         },          "hapticMode": {            "type": "integer",
	    "minimum": 0,            "maximum": 1,            "description": "The haptic feedback mode for the knob."          },          "hapticIndent1": {            "type": "integer",
	    "minimum": 0,            "maximum": 127,            "description": "A haptic parameter (indentation 1) used for tactile feedback."          },          "hapticIndent2": {            "type": "integer",
	    "minimum": 0,            "maximum": 127,            "description": "A second haptic parameter (indentation 2) for tactile feedback."          },          "hapticSteps": {            "type": "integer",
	    "minimum": 0,            "maximum": 16,            "description": "The number of haptic steps for the knob control."          },          "stepNames": {            "type": "array",            "description": "An array of 16 step names associated with this control (one per step).",            "items": {              "type": "string"            },            "minItems": 16,            "maxItems": 16          }        },        "required": [          "controlIndex",          "controlMode",          "controlChannel",          "controlParam",          "nrpnAddress",          "minValue",          "maxValue",          "controlName",          "colorScheme",          "hapticMode",          "hapticIndent1",          "hapticIndent2",          "hapticSteps",          "stepNames"        ],        "additionalProperties": false      }    },    "buttons": {      "type": "array",      "description": "An array of button control definitions.",      "items": {        "type": "object",        "description": "Definition of a single button control.",        "properties": {          "controlIndex": {	    "minimum": 0,            "maximum": 31,            "type": "integer",            "description": "The index of the button control."          },          "controlMode": {            "type": "integer",            "description": "The mode of the button control."          },          "controlChannel": {            "type": "integer",	    "minimum": 1,            "maximum": 16,            "description": "The MIDI channel assigned to this button."          },          "controlParam": {            "type": "integer",
	    "minimum": 0,            "maximum": 127,            "description": "The MIDI parameter number for the button."          },          "nrpnAddress": {            "type": "integer",            "description": "The NRPN address for the button, if applicable."          },          "minValue": {            "type": "integer",	    "minimum": 0,            "maximum": 127,            "description": "The minimum value that the button control can produce."          },          "maxValue": {            "type": "integer",	    "minimum": 0,            "maximum": 127,            "description": "The maximum value that the button control can produce."          },          "controlName": {            "type": "string",            "description": "A descriptive name for the button."          },          "colorScheme": {            "type": "integer",	    "minimum": 0,            "maximum": 82,            "description": "An identifier for the button's color scheme."          },          "ledOnColor": {            "type": "integer",	    "minimum": 0,            "maximum": 82,            "description": "The color value used when the button's LED is on."          },          "ledOffColor": {            "type": "integer",	    "minimum": 0,            "maximum": 82,            "description": "The color value used when the button's LED is off."          },          "hapticMode": {            "type": "integer",
	    "minimum": 0,            "maximum": 1,            "description": "The haptic feedback mode for the button."          },          "hapticSteps": {            "type": "integer",
	    "minimum": 0,            "maximum": 16,            "description": "The number of haptic steps for the button."          },          "stepNames": {            "type": "array",            "description": "An array of 16 step names associated with this button (one per step).",            "items": {              "type": "string"            },            "minItems": 16,            "maxItems": 16          }        },        "required": [          "controlIndex",          "controlMode",          "controlChannel",          "controlParam",          "nrpnAddress",          "minValue",          "maxValue",          "controlName",          "colorScheme",          "ledOnColor",          "ledOffColor",          "hapticMode",          "hapticSteps",          "stepNames"        ],        "additionalProperties": false      }    }  },  "required": ["version", "type", "name", "index", "knobs", "buttons"],  "additionalProperties": false}